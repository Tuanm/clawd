# Claw'd Environment Variables
# Copy this file to .env and fill in the values.
# Lines starting with # are comments.

# ─── Server ──────────────────────────────────────────────────────────────────

# HTTP port the server listens on (default: 3456)
PORT=3456

# Deployment environment: dev | prod | staging | local
# Controls in-container vs local database path selection.
ENV=dev

# ─── System / Shell ───────────────────────────────────────────────────────────

# Override default shell (default: /bin/bash on Linux/macOS)
# SHELL=/bin/bash

# Locale for spawned processes (default: C.UTF-8)
# LANG=C.UTF-8

# User for spawned processes (default: clawd)
# USER=clawd

# Home directory override
# HOME=/home/clawd

# XDG cache directory (default: ~/.cache)
# XDG_CACHE_HOME=/home/clawd/.cache

# Terminal program identifier used for telemetry/headers
# TERM_PROGRAM=vscode

# ─── Sandbox ─────────────────────────────────────────────────────────────────

# Set to "true" to require sandbox mode for all agent sessions.
# If true, sessions without a sandbox will be rejected.
CLAWD_REQUIRE_SANDBOX=false

# ─── Display & Desktop ───────────────────────────────────────────────────────

# X display for headless GUI tools (default: :99)
# DISPLAY=:99

# noVNC port for browser-based desktop access (default: 6080)
# NOVNC_PORT=6080

# ─── Remote Worker ────────────────────────────────────────────────────────────

# Auth token for remote worker connections
# CLAWD_WORKER_TOKEN=

# Cloudflare Access client ID (for CF-protected deployments)
# CF_ACCESS_CLIENT_ID=

# Cloudflare Access client secret
# CF_ACCESS_CLIENT_SECRET=

# Wayland display socket (alternative to DISPLAY on Wayland compositors)
# WAYLAND_DISPLAY=wayland-0

# Override temporary directory
# TMPDIR=/tmp

# Path to custom CA certificate bundle (for corporate proxies / self-signed TLS)
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt

# Set to "0" to disable TLS verification (NOT recommended for production)
# NODE_TLS_REJECT_UNAUTHORIZED=1
