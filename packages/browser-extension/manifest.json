{
  "manifest_version": 3,
  "name": "Claw'd",
  "version": "1.0.0",
  "description": "Connect your browser to Claw'd AI agents for browser automation and collaboration.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "debugger",
    "offscreen",
    "storage",
    "cookies",
    "downloads",
    "downloads.ui"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Claw'd"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/app-icon-16.png",
    "48": "icons/app-icon-48.png",
    "128": "icons/app-icon-128.png"
  },
  "incognito": "spanning"
}
