{
  "manifest_version": 3,
  "name": "Claw'd Browser",
  "version": "1.0.0",
  "description": "Connect your browser to Claw'd AI agents for browser automation and collaboration.",
  "permissions": ["activeTab", "tabs", "scripting", "debugger", "offscreen", "storage"],
  "host_permissions": ["http://localhost:*/*", "http://127.0.0.1:*/*", "http://*/*"],
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Claw'd Browser"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/disconnected-16.png",
    "48": "icons/disconnected-48.png",
    "128": "icons/disconnected-128.png"
  }
}
