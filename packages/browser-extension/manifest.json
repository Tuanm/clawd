{
  "manifest_version": 3,
  "name": "Claw'd Browser Bridge",
  "version": "1.0.0",
  "description": "Connect your browser to Claw'd AI agents for browser automation and collaboration.",
  "permissions": ["activeTab", "tabs", "scripting", "debugger", "offscreen"],
  "host_permissions": ["http://localhost:*/*", "http://127.0.0.1:*/*"],
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Claw'd Browser Bridge"
  },
  "offscreen": {
    "reasons": ["WORKERS"],
    "justification": "Maintains persistent WebSocket connection to local Claw'd server"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
